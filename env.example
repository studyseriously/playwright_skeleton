# ==============================================================
# ENVIRONMENT VARIABLES — EXAMPLE TEMPLATE
# ==============================================================
#
# WHAT IS THIS FILE?
# ------------------
# This is a TEMPLATE showing every environment variable the
# test suite needs. It contains fake placeholder values only.
#
# WHAT YOU NEED TO DO:
# ------------------
# 1. Copy this file and rename the copy to: .env
#      cp .env.example .env
#
# 2. Open .env and replace every placeholder value with your
#    real credentials.
#
# 3. NEVER commit .env to git — it is listed in .gitignore.
#    This .env.example file IS safe to commit — it has no
#    real credentials in it.
#
# FOR CI (GitHub Actions):
# ------------------
# These variables are stored as GitHub Actions Secrets.
# Go to: GitHub repo → Settings → Secrets and variables →
#        Actions → New repository secret
# Add each variable below as a separate secret.
# The GitHub Actions workflow injects them automatically.
# ==============================================================


# --------------------------------------------------------------
# TEST ACCOUNT CREDENTIALS
# --------------------------------------------------------------
# The email and password of the test user account.
# This account must:
#   - Have access to the staging portal
#   - Have at least one active WhatsApp channel configured
#   - Have permission to access the Campaign Manager module
# --------------------------------------------------------------
TEST_EMAIL=your-test-email@example.com
TEST_PASSWORD=your-test-password-here


# --------------------------------------------------------------
# TEST USER DISPLAY NAME
# --------------------------------------------------------------
# The full name displayed in the sidebar after login.
# Used in auth.setup.ts to confirm login succeeded.
# Must match exactly what appears in the sidebar footer.
# Example: Hassan Saad
# --------------------------------------------------------------
TEST_USER_NAME=Your Full Name Here


# --------------------------------------------------------------
# TEST DATA — CAMPAIGN WIZARD
# --------------------------------------------------------------
# Values used to fill in the campaign creation wizard.
# Keeping them here means you can change test data without
# touching the test file itself.

# The name of the campaign created in the test.
# Make it recognizable so you can spot it in the campaign table.
# Tip: include a timestamp in the actual value so each run
# creates a uniquely named campaign and doesn't conflict with
# previous runs. You can do this in the test file itself using:
#   `${process.env.TEST_CAMPAIGN_NAME} ${Date.now()}`
TEST_CAMPAIGN_NAME=QA Automated Test Campaign

# The exact name of the WhatsApp channel to select in Step 1.
# Must match the visible text of an ACTIVE channel in the dropdown.
# Log into the portal manually and check the channel dropdown.
TEST_CHANNEL_NAME=Your WhatsApp Channel Name Here

# The AI description/prompt entered in Step 1 when "Handled By AI"
# is selected. Keep it short but realistic.
TEST_CAMPAIGN_DESCRIPTION=This is an automated test campaign created by Playwright. Please ignore.
# --------------------------------------------------------------


# --------------------------------------------------------------
# APP URLs (optional — already set in playwright.config.ts)
# --------------------------------------------------------------
# These are already hardcoded in playwright.config.ts.
# Define them here ONLY if you want to override the config
# without editing the config file directly.
# Leave them commented out unless needed.
# --------------------------------------------------------------
# BASE_URL=https://app-testing.trypair.ai
# API_BASE_URL=https://system.trypair.ai
